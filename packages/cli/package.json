{
  "name": "guardgate",
  "version": "0.1.1",
  "description": "GuardGate CLI — secrets scanning, SBOM/CVE tracking, and security E2E testing",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "guardgate": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run --config vitest.integration.config.ts"
  },
  "keywords": [
    "security",
    "cli",
    "secrets",
    "sbom",
    "e2e"
  ],
  "license": "MIT",
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "fast-glob": "^3.3.2",
    "ignore": "^5.3.1",
    "ora": "^8.0.1",
    "playwright": "^1.45.0",
    "simple-git": "^3.36.0",
    "typescript": "^5.9.3",
    "yaml": "^2.4.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "vitest": "^1.6.0"
  }
}
